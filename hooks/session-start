#!/bin/bash
# SessionStart hook for FDEOS
# Loads @fde entry point and .fde/context.md at session start

SKILL_DIR="$(dirname "$0")/../skills"
BOOTSTRAP="$SKILL_DIR/fde/SKILL.md"
CONTEXT_FILE=".fde/context.md"

CONTENT=""

if [ -f "$BOOTSTRAP" ]; then
    CONTENT="$CONTENT$(cat $BOOTSTRAP)\n\n"
fi

if [ -f "$CONTEXT_FILE" ]; then
    CONTENT="$CONTENT---\nEngagement context loaded from .fde/context.md:\n$(cat $CONTEXT_FILE)\n"
fi

if [ -n "$COPILOT_CLI" ]; then
    echo "{\"additionalContext\": $(echo -e "$CONTENT" | jq -Rs .)}"
else
    echo -e "$CONTENT"
fi
